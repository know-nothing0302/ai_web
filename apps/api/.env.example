NODE_ENV=production
PORT=3000
SESSION_SECRET=replace-with-strong-secret
APP_BASE_URL=https://your-domain.edu.cn
WEB_BASE_URL=https://your-domain.edu.cn

# 认证配置
CAS_LOGIN_URL=https://your-cas-server.edu.cn/authserver/login
CAS_VALIDATE_URL=https://your-cas-server.edu.cn/authserver/serviceValidate
CAS_SERVICE_URL=https://your-domain.edu.cn/api/auth/cas/callback
CAS_LOGOUT_URL=https://your-cas-server.edu.cn/authserver/logout
DEV_AUTH_BYPASS=false
WECOM_APP_CODE=default
WECOM_BASE_URL=https://qyapi.weixin.qq.com/cgi-bin
WECOM_CORP_ID=
WECOM_AGENT_ID=1000002
WECOM_SECRET=
WECOM_PUSH_AGENT_ID=
WECOM_PUSH_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
WECOM_INTERNAL_AUTH_TOKEN=
WECOM_REQUEST_TIMEOUT_MS=5000
WECOM_TOKEN_REFRESH_SKEW_SECONDS=300
PUSH_TIMEZONE=Asia/Shanghai
DAILY_PUSH_CRON=0 20 * * *
WEEKLY_PUSH_CRON=0 20 * * 0
DEFERRED_INSTANT_PUSH_CRON=0 8 * * *
INSTANT_PUSH_WINDOW_START_HOUR=8
INSTANT_PUSH_WINDOW_END_HOUR=20
AI_XY_API_URL=http://localhost:8001
AI_XY_API_KEY=
AI_XY_DEFAULT_USER_ID=your-user-id
AI_XY_DEFAULT_KNOWLEDGE_GPT_ID=2476
AI_XY_DEFAULT_CHAT_TYPE=ZSH_CHAT
AI_XY_DEFAULT_GPT_TYPE=deepseekR1_zsh
DEEPSEEK_USER_ID_SECRET=                                          # HMAC-SHA256 密钥，用于伪匿名化用户ID传给DeepSeek
ARTICLE_PUBLISH_JWT_ISSUER=ai_web_publish
ARTICLE_PUBLISH_JWT_AUDIENCE=ai_web_articles
ARTICLE_PUBLISH_JWT_TTL_SECONDS=900
ARTICLE_PUBLISH_JWT_MAX_TTL_SECONDS=900
ARTICLE_PUBLISH_JWT_ACTIVE_KID=v1
ARTICLE_PUBLISH_JWT_PUBLIC_KEYS=v1:base64:replace-with-base64-encoded-rsa-public-pem
ARTICLE_PUBLISH_JWT_PRIVATE_KEYS=v1:base64:replace-with-base64-encoded-rsa-private-pem
ARTICLE_PUBLISH_TOKEN_CLIENTS=workbuddy:replace-with-strong-client-secret,hermes:replace-with-strong-client-secret
ARTICLE_PUBLISH_ALLOWED_USER_IDS=your-user-id

# 生日祝福系统
BIRTHDAY_PUSH_MODE=test                  # test | production，默认 test

# Oracle 身份数据源
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=your-oracle-host/service_name
